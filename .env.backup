# =====================================================
# ENHANCED TOWNTAP ENVIRONMENT CONFIGURATION
# Hyperlocal Business Ecosystem Configuration
# =====================================================

# Supabase Configuration (Demo Mode - Replace with your Supabase project)
EXPO_PUBLIC_SUPABASE_URL=https://demo.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=demo-key
SUPABASE_SERVICE_ROLE_KEY=demo-service-key

# App Configuration
EXPO_PUBLIC_APP_NAME=Enhanced TownTap
EXPO_PUBLIC_APP_VERSION=2.0.0
EXPO_PUBLIC_ENVIRONMENT=development

# Core Features Configuration
EXPO_PUBLIC_ENABLE_REALTIME=true
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_AI_FEATURES=true
EXPO_PUBLIC_ENABLE_VOICE_SEARCH=true
EXPO_PUBLIC_ENABLE_CHAT_SUPPORT=true
EXPO_PUBLIC_ENABLE_LOYALTY_PROGRAM=true

# API Configuration
EXPO_PUBLIC_API_TIMEOUT=15000
EXPO_PUBLIC_MAX_RETRIES=3
EXPO_PUBLIC_RETRY_DELAY=1000

# Location Configuration (Bhopal, MP as default)
EXPO_PUBLIC_DEFAULT_LATITUDE=23.2599
EXPO_PUBLIC_DEFAULT_LONGITUDE=77.4126
EXPO_PUBLIC_DEFAULT_CITY=Bhopal
EXPO_PUBLIC_DEFAULT_STATE=Madhya Pradesh
EXPO_PUBLIC_DEFAULT_RADIUS=20
EXPO_PUBLIC_MAX_SEARCH_RADIUS=50

# Business Configuration
EXPO_PUBLIC_MIN_ORDER_AMOUNT=50
EXPO_PUBLIC_DEFAULT_DELIVERY_FEE=25
EXPO_PUBLIC_DEFAULT_DELIVERY_TIME=30
EXPO_PUBLIC_MAX_DELIVERY_TIME=120
EXPO_PUBLIC_COMMISSION_RATE=5.0

# Payment Configuration
EXPO_PUBLIC_ENABLE_WALLET=true
EXPO_PUBLIC_ENABLE_UPI_DIRECT=true
EXPO_PUBLIC_ENABLE_COD=true
EXPO_PUBLIC_MIN_WALLET_TOPUP=100
EXPO_PUBLIC_MAX_WALLET_BALANCE=50000

# AI Configuration
EXPO_PUBLIC_AI_MODEL=gemini-pro
EXPO_PUBLIC_AI_MAX_TOKENS=1000
EXPO_PUBLIC_AI_TEMPERATURE=0.7
EXPO_PUBLIC_ENABLE_AI_SUGGESTIONS=true
EXPO_PUBLIC_ENABLE_AI_CONTENT_GENERATION=true

# Loyalty & Rewards
EXPO_PUBLIC_POINTS_PER_RUPEE=1
EXPO_PUBLIC_REFERRAL_BONUS=100
EXPO_PUBLIC_SIGNUP_BONUS=50
EXPO_PUBLIC_REVIEW_BONUS=10

# Media Configuration
EXPO_PUBLIC_MAX_IMAGE_SIZE=5242880
EXPO_PUBLIC_MAX_VIDEO_SIZE=52428800
EXPO_PUBLIC_SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png,webp
EXPO_PUBLIC_SUPPORTED_VIDEO_FORMATS=mp4,mov

# Performance Configuration
EXPO_PUBLIC_IMAGE_QUALITY=0.8
EXPO_PUBLIC_THUMBNAIL_SIZE=300
EXPO_PUBLIC_CACHE_DURATION=300000
EXPO_PUBLIC_OFFLINE_CACHE_SIZE=100

# Security Configuration
EXPO_PUBLIC_SESSION_TIMEOUT=86400
EXPO_PUBLIC_MAX_LOGIN_ATTEMPTS=5
EXPO_PUBLIC_LOCKOUT_DURATION=900

# Business Hours Configuration
EXPO_PUBLIC_DEFAULT_OPENING_TIME=09:00
EXPO_PUBLIC_DEFAULT_CLOSING_TIME=22:00
EXPO_PUBLIC_EMERGENCY_SERVICE_MULTIPLIER=1.5

# Notification Configuration
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_EMAIL_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_SMS_NOTIFICATIONS=true

# Development Tools
EXPO_PUBLIC_ENABLE_DEBUG_MODE=true
EXPO_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
EXPO_PUBLIC_LOG_LEVEL=debug

# Third-party API Keys (Add your actual keys here)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_here
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Social Login Configuration
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id_here
EXPO_PUBLIC_APPLE_CLIENT_ID=your_apple_client_id_here
