{
  "name": "enhanced-towntap",
  "main": "expo-router/entry",
  "version": "2.0.0",
  "description": "Enhanced TownTap - Hyperlocal Business Ecosystem with AI Integration",
  "keywords": [
    "hyperlocal",
    "business",
    "ai",
    "marketplace",
    "react-native"
  ],
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "start:tunnel": "expo start --tunnel",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "clean": "expo r -c"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-picker/picker": "^2.11.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/drawer": "^6.7.6",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@react-navigation/stack": "^6.4.5",
    "@supabase/supabase-js": "^2.52.0",
    "@tanstack/react-query": "^5.45.1",
    "date-fns": "^3.6.0",
    "expo": "~53.0.16",
    "expo-av": "~15.1.7",
    "expo-blur": "~14.1.5",
    "expo-camera": "~16.1.5",
    "expo-clipboard": "^7.1.5",
    "expo-constants": "~17.1.6",
    "expo-dev-client": "~5.0.11",
    "expo-device": "^7.1.4",
    "expo-file-system": "~18.0.11",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.0",
    "expo-image-picker": "^16.1.4",
    "expo-linear-gradient": "^14.1.5",
    "expo-linking": "~7.1.6",
    "expo-localization": "^16.1.6",
    "expo-location": "^18.1.6",
    "expo-media-library": "~17.1.4",
    "expo-notifications": "^0.31.4",
    "expo-router": "~5.1.2",
    "expo-secure-store": "~14.1.6",
    "expo-splash-screen": "~0.30.9",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.10",
    "expo-web-browser": "~14.2.0",
    "i18next": "^23.15.1",
    "lottie-react-native": "7.2.2",
    "moti": "^0.30.0",
    "native-base": "^3.4.29",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^15.6.1",
    "react-native": "0.79.5",
    "react-native-animatable": "^1.4.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-maps": "1.20.1",
    "react-native-modal": "^13.0.1",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-shared-element": "^0.8.9",
    "react-native-super-grid": "^5.1.1",
