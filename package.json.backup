  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.1.0",
    "@types/react": "~19.0.10",
    "@types/react-i18next": "^8.1.0",
    "@types/react-native": "^0.73.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "jest": "^29.7.0",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "react-native"
  },
  "private": true
