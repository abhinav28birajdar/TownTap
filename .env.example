# =====================================================
# TownTap Enhanced Environment Configuration
# =====================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# =====================================================
# APP CONFIGURATION
# =====================================================
EXPO_PUBLIC_APP_NAME=TownTap
EXPO_PUBLIC_APP_VERSION=2.0.0
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_BUNDLE_ID=com.towntap.app
EXPO_PUBLIC_DEBUG_MODE=true

# =====================================================
# SUPABASE CONFIGURATION (Required)
# =====================================================
# Get these from your Supabase project settings
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
EXPO_PUBLIC_SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1

# =====================================================
# PAYMENT GATEWAY - RAZORPAY (Required)
# =====================================================
# Get these from Razorpay Dashboard: https://dashboard.razorpay.com/
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PAYOUT_ACCOUNT_ID=your_payout_account_id

# =====================================================
# AI SERVICES (Required for AI features)
# =====================================================
# Google Gemini API (Primary)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# OpenAI API (Backup/Alternative)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# =====================================================
# PUSH NOTIFICATIONS (Required)
# =====================================================
# Firebase Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key
EXPO_PUBLIC_FCM_SENDER_ID=your_fcm_sender_id

# Expo Push Notifications (Alternative)
EXPO_ACCESS_TOKEN=your_expo_access_token

# =====================================================
# SMS & COMMUNICATION (Required for OTP)
# =====================================================
# Twilio (for SMS/OTP)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Business API (Optional)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# Email Service (Optional)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@towntap.in

# =====================================================
# MAPS & LOCATION SERVICES (Required)
# =====================================================
# Google Maps Platform
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Mapbox (Alternative)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# =====================================================
# FILE STORAGE (Optional - Supabase Storage is primary)
# =====================================================
# Cloudinary
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AWS S3 (Alternative)
AWS_S3_BUCKET=your_s3_bucket
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# =====================================================
# ANALYTICS & MONITORING (Optional)
# =====================================================
EXPO_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn
EXPO_PUBLIC_AMPLITUDE_API_KEY=your_amplitude_api_key

# =====================================================
# BUSINESS CONFIGURATION
# =====================================================
EXPO_PUBLIC_MIN_ORDER_AMOUNT=50
EXPO_PUBLIC_DEFAULT_DELIVERY_FEE=25
EXPO_PUBLIC_DEFAULT_DELIVERY_TIME=30
EXPO_PUBLIC_COMMISSION_RATE=0.15
EXPO_PUBLIC_PAYOUT_THRESHOLD=1000

# =====================================================
# LOCATION SETTINGS
# =====================================================
# Default location (Mumbai, India)
EXPO_PUBLIC_DEFAULT_LATITUDE=19.0760
EXPO_PUBLIC_DEFAULT_LONGITUDE=72.8777
EXPO_PUBLIC_DEFAULT_RADIUS=20
EXPO_PUBLIC_MAX_SEARCH_RADIUS=50

# =====================================================
# API CONFIGURATION
# =====================================================
EXPO_PUBLIC_API_TIMEOUT=15000
EXPO_PUBLIC_MAX_RETRIES=3
EXPO_PUBLIC_RATE_LIMIT=100

# =====================================================
# FEATURE FLAGS
# =====================================================
EXPO_PUBLIC_ENABLE_REALTIME=true
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_AI_FEATURES=true
EXPO_PUBLIC_ENABLE_PAYMENT_GATEWAY=true
EXPO_PUBLIC_ENABLE_LOYALTY_PROGRAM=true
EXPO_PUBLIC_ENABLE_VOICE_SEARCH=false
EXPO_PUBLIC_ENABLE_AR_FEATURES=false
EXPO_PUBLIC_ENABLE_DARK_MODE=true

# =====================================================
# MULTILINGUAL SUPPORT
# =====================================================
EXPO_PUBLIC_DEFAULT_LANGUAGE=en
EXPO_PUBLIC_SUPPORTED_LANGUAGES=en,hi
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key

# =====================================================
# SECURITY CONFIGURATION
# =====================================================
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30
OTP_EXPIRY_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
ENCRYPTION_KEY=your_32_character_encryption_key

# =====================================================
# DEVELOPMENT/TESTING
# =====================================================
EXPO_PUBLIC_REALTIME_EVENTS_PER_SECOND=10

# =====================================================
# SOCIAL MEDIA & LINKS
# =====================================================
EXPO_PUBLIC_WEBSITE_URL=https://towntap.in
EXPO_PUBLIC_SUPPORT_EMAIL=support@towntap.in
EXPO_PUBLIC_SUPPORT_PHONE=+911234567890
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://towntap.in/privacy
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://towntap.in/terms

# =====================================================
# NOTES FOR SETUP:
# =====================================================
# 1. Supabase: Create project at https://supabase.com
# 2. Razorpay: Sign up at https://razorpay.com
# 3. Google Cloud: Enable Maps API at https://console.cloud.google.com
# 4. Gemini AI: Get API key from https://makersuite.google.com/app/apikey
# 5. Firebase: Setup project at https://console.firebase.google.com
# 6. Twilio: Create account at https://www.twilio.com
# 7. For production, change EXPO_PUBLIC_ENVIRONMENT to 'production'
