# TownTap Environment Variables
# Copy this file to .env and update with your actual values

# ================================
# SUPABASE CONFIGURATION
# ================================
# Get these from your Supabase project dashboard: https://app.supabase.com

# Your Supabase project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon key (safe to expose in client)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase service role key (KEEP SECRET - server-side only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ================================
# REALTIME CONFIGURATION
# ================================
# Supabase Realtime settings
EXPO_PUBLIC_REALTIME_EVENTS_PER_SECOND=10

# ================================
# APPLICATION SETTINGS
# ================================
# Default app configuration
EXPO_PUBLIC_DEFAULT_CITY=Bhopal
EXPO_PUBLIC_DEFAULT_RADIUS_KM=20
EXPO_PUBLIC_APP_NAME=TownTap

# ================================
# DEVELOPMENT SETTINGS
# ================================
# Set to true for development mode features
EXPO_PUBLIC_DEV_MODE=true

# ================================
# API CONFIGURATION
# ================================
# External API keys (if any)
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# EXPO_PUBLIC_ANALYTICS_API_KEY=your_analytics_api_key

# ================================
# PUSH NOTIFICATIONS
# ================================
# Expo push notification settings
# EXPO_PUBLIC_PUSH_NOTIFICATIONS_ENABLED=true

# ================================
# INSTRUCTIONS
# ================================
# 1. Sign up at https://supabase.com
# 2. Create a new project
# 3. Copy your project URL and anon key from Settings > API
# 4. Replace the placeholder values above
# 5. Run the DATABASE_SCHEMA.sql file in your Supabase SQL editor
# 6. Save this file as .env in your project root
