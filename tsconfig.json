{
  "compilerOptions": {
    "lib": ["ES2015", "ES2017", "ES2018", "ES2019", "ES2020"],
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "ignoreDeprecations": "5.0",
    "noEmit": true,
    "isolatedModules": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false
  },
  "extends": "expo/tsconfig.base",
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "App.tsx",
    "index.js"
  ],
  "exclude": [
    "node_modules",
    "supabase/**/*",
    "supabase/functions/**/*",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "coverage/**/*",
    "dist/**/*",
    ".expo/**/*"
  ]
}
